menu "TOF initiator options"

config TOF_RESP_EXPECT_DELAY_UUS
    int "Expected responder delay (UUS)"
    default 250
    range 100 2000
    help
      Expected delay between POLL transmission and RESP reception in
      UWB microseconds (UUS). This should match the responder's
      CONFIG_TOF_RESP_DELAY_UUS value for accurate range calculation.

config TOF_RESP_RX_TIMEOUT_UUS
    int "Response RX timeout (UUS)"
    default 1000
    range 100 10000
    help
      Receive timeout used while waiting for the responder's SSTWR
      response. Increase this if the responder delay is large.

config TOF_RANGING_PERIOD_MS
    int "Ranging period (ms)"
    default 200
    range 20 1000
    help
      Time in milliseconds between successive SSTWR polls emitted by
      the initiator.

endmenu

source "Kconfig.zephyr"


