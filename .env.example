# Environment Configuration for Drone Project
# Copy this file to .env and customize as needed

# ===== ROS2 Configuration =====
ROS_DISTRO=humble
ROS_DOMAIN_ID=42

# ===== Display Configuration =====
# Linux/macOS: Use current display
DISPLAY=:0
# Windows: Use VcXsrv or similar
# DISPLAY=host.docker.internal:0.0

# ===== Development Configuration =====
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO
DEBUG_MODE=false

# ===== Simulation Configuration =====
GAZEBO_MODEL_PATH=/workspace/simulation/models
GAZEBO_WORLD_PATH=/workspace/simulation/worlds
SIMULATION_GUI=true

# ===== Hardware Configuration =====
# Hardware interface mode: simulation, hardware, mixed
DRONE_HARDWARE_INTERFACE=simulation

# UWB Configuration
UWB_ANCHOR_COUNT=4
UWB_TAG_ADDRESS=0x1001
UWB_ANCHOR_ADDRESSES=0x1010,0x1011,0x1012,0x1013

# Serial ports for hardware interface
FLIGHT_CONTROLLER_PORT=/dev/ttyUSB0
ESP32_PORT=/dev/ttyUSB1
STM32_PORT=/dev/ttyACM0

# ===== Database Configuration =====
POSTGRES_DB=drone_logs
POSTGRES_USER=drone
POSTGRES_PASSWORD=drone_password
POSTGRES_HOST=database
POSTGRES_PORT=5432

# ===== Monitoring Configuration =====
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ===== Security Configuration =====
# API Keys (keep these secret!)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ===== Network Configuration =====
# Docker network subnet
DOCKER_SUBNET=172.20.0.0/16

# Port mappings
DEV_HTTP_PORT=8080
DEV_WEBSOCKET_PORT=3000
DOCS_PORT=8000
ROS_MASTER_PORT=11311
ROS_DISCOVERY_PORT=11345

# ===== Development Tools =====
# Python configuration
PYTHONPATH=/workspace
PYTHON_VERSION=3.10

# Build configuration
CMAKE_BUILD_TYPE=Debug
COLCON_WS=/workspace/ros2_ws

# Git configuration
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your.email@example.com

# ===== Feature Flags =====
ENABLE_HARDWARE_TESTING=false
ENABLE_ML_TRAINING=true
ENABLE_DATA_LOGGING=true
ENABLE_TELEMETRY=true

# ===== Performance Configuration =====
# Memory limits for containers (in MB)
DEV_MEMORY_LIMIT=4096
SIMULATION_MEMORY_LIMIT=2048
TEST_MEMORY_LIMIT=1024

# CPU limits (number of cores)
DEV_CPU_LIMIT=2.0
SIMULATION_CPU_LIMIT=1.0

# ===== Backup Configuration =====
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30

# ===== Logging Configuration =====
LOG_FORMAT=json
LOG_ROTATION_SIZE=100MB
LOG_RETENTION_COUNT=10

# Application-specific log levels
ROS2_LOG_LEVEL=INFO
GAZEBO_LOG_LEVEL=ERROR
DOCKER_LOG_LEVEL=WARN

# ===== Custom Configuration =====
# Add your custom environment variables below
# CUSTOM_VAR=value